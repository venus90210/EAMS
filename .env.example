# ── Base de datos ──────────────────────────────────────────────────────────
POSTGRES_DB=eams_dev
POSTGRES_USER=eams
POSTGRES_PASSWORD=
DATABASE_URL=jdbc:postgresql://localhost:5432/eams_dev

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:@localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ── Email (SMTP / API transaccional) ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@eams.edu.co

# ── Backend (Spring Boot) ──────────────────────────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ── API Gateway (NestJS) ───────────────────────────────────────────────────
GATEWAY_PORT=3000
BACKEND_URL=http://backend:8080

# ── Frontend (Next.js) ─────────────────────────────────────────────────────
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
